# AI Provider: deepseek (默认) | kimi
AI_PROVIDER=deepseek

# DeepSeek API（充支付宝即可使用，OpenAI 兼容接口）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Kimi / Moonshot API（可选，设置 AI_PROVIDER=kimi 后使用，OpenAI 兼容接口）
# 同时用于 Embeddings 语义搜索
MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-8k

# Embedding Provider（语义搜索）: siliconflow (默认, 免费) | openai | kimi | local
EMBEDDING_PROVIDER=siliconflow
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OpenAI API Key（仅当 EMBEDDING_PROVIDER=openai 时使用）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
